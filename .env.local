# =============================================================================
# REDIS (for BullMQ workers)
# =============================================================================
# Redis connection URL (Redis Cloud, Upstash, or local)
REDIS_URL=redis://localhost:6379

# Or use individual components:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# STRIPE
# =============================================================================
# Stripe publishable key (safe for browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# Stripe secret key (server-side only)
STRIPE_SECRET_KEY=sk_test_your-key

# Stripe webhook signing secret (from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs for subscription plans
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_PROFESSIONAL=price_professional_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_id

# =============================================================================
# EMAIL (Resend)
# =============================================================================
# Resend API key for transactional emails
RESEND_API_KEY=re_your-key

# From email address
RESEND_FROM_EMAIL=alerts@axiom-intelligence.com

# =============================================================================
# APP CONFIG
# =============================================================================
# Public URL of your app (used for redirects, webhooks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App environment
NODE_ENV=development

# =============================================================================
# EXTERNAL DATA SOURCES
# =============================================================================
# GDELT API base URL (public, no key needed)
GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc

# RSS feed URLs (comma-separated)
RSS_FEED_URLS=https://feeds.reuters.com/reuters/worldNews,https://feeds.bbci.co.uk/news/world/rss.xml
